{
  "domain": "lastmanagement",
  "name": "Lastmanagement (Test)",
  "documentation": "https://github.com/cwoerndl/ha-lastmanagement",
  "dependencies": [],
  "arch": ["amd64", "armhf", "armv7", "aarch64"],
  "machine": ["qemux86-64", "raspberrypi4", "raspberrypi3"],
  "version": "0.1.0",
  "slug": "lastmanagement",
  "description": "Minimales Lastmanagement-Add-on zum Testen",
  "url": "https://github.com/cwoerndl/ha-lastmanagement",
  "startup": "application",
  "boot": "auto",
  "options": {
    "log_level": "info",
    "update_interval": 30
  },
  "schema": {
    "log_level": {
      "type": "select",
      "default": "info",
      "options": ["debug", "info", "warning", "error"]
    },
    "update_interval": {
      "type": "integer",
      "default": 30,
      "min": 5,
      "max": 300,
      "description": "Aktualisierungsintervall in Sekunden"
    }
  },
  "privileged": false,
  "full_access": false,
  "homeassistant_api": true,
  "host_network": false,
  "host_pid": false,
  "host_dbus": false,
  "apparmor": false,
  "image": "ghcr.io/hassio-addons/base/{arch}"
}